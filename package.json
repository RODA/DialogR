{
    "private": true,
    "scripts": {
        "check": "node scripts/check-product.js",
        "build": "node scripts/build-product.js",
        "check:build-ownership": "node scripts/check-build-ownership.js",
        "webr:library": "node scripts/download-webr-library.js",
        "verify:electron-dialog": "node tests/electron/verify-DialogR-dialog-window.js",
        "dev:web": "node scripts/run-dialogforge-web.js --replace-port",
        "build:web": "node scripts/run-dialogforge-web.js --build-only",
        "serve:web": "node scripts/run-dialogforge-web.js --no-build --replace-port",
        "verify:web-deployment": "node scripts/verify-web-deployment.js"
    },
    "devDependencies": {
        "@dialogforge/core": "file:../DialogForge/dist/sdk/core"
    },
    "name": "dialogr",
    "version": "1.0.17",
    "description": "A dialog-driven desktop application for statistical analysis in R.",
    "author": "Adrian Dusa",
    "contributors": [
        "RODA"
    ],
    "license": "SEE LICENSE IN LICENSE",
    "build": {
        "extraResources": [
            "LICENSE"
        ],
        "mac": {
            "extendInfo": {
                "NSHumanReadableCopyright": "© 2025-2026 Adrian Dusa — Academic Non-Commercial License (see LICENSE file for details)."
            },
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "arm64"
                    ]
                }
            ]
        },
        "win": {
            "legalTrademarks": "Academic Non-Commercial License (see LICENSE file for details).",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "linux": {
            "target": [
                {
                    "target": "AppImage",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        }
    },
    "product": {
        "id": "DialogR",
        "name": "DialogR",
        "appId": "org.roda.dialogr",
        "defaultRuntimeProvider": "r",
        "autoUpdate": {
            "releaseRepository": "dusadrian/binaries",
            "releaseTag": "drms"
        },
        "runtimeProviders": [
            "r",
            "server-r",
            "webr"
        ],
        "webRPackageLibrary": {
            "releaseTag": "drweb"
        }
    }
}
